# ── Environment ───────────────────────────────────────────────────────────────
# .env.example / .env.prod.example are tracked (templates with no real secrets)
# .env / .env.prod contain real secrets — NEVER commit them
.env
.env.prod
.env.local
.env.*.local
.envrc           # direnv


# ── Virtual Environments ──────────────────────────────────────────────────────
# uv creates .venv by default — never track it
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/


# ── uv ────────────────────────────────────────────────────────────────────────
# uv.lock IS intentionally tracked (reproducible installs for the whole team).
# Uncomment only if you explicitly do NOT want lock-file tracking:
# uv.lock

# uv HTTP cache lives in ~/.cache/uv — nothing to ignore in the project dir


