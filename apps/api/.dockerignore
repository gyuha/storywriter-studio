# ============================================================
# .dockerignore — FastAPI Bootstrap
# ============================================================
# Keep the build context lean: exclude dev artefacts, local env
# files, caches, and anything that shouldn't enter the image.
# ============================================================

# ── Python cache / compiled files ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── uv cache ──────────────────────────────────────────────────────────────────
.cache/uv/

# ── Build / dist artefacts ────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Test / coverage artefacts ─────────────────────────────────────────────────
tests/
conftest.py
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
*.lcov

# ── Type / lint caches ────────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ── IDE / editor files ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes
.github/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.prod.example

# ── Documentation ─────────────────────────────────────────────────────────────
docs/
*.md
!README.md

# ── Docker files (no need inside the image) ───────────────────────────────────
Dockerfile*
docker-compose*.yml
.dockerignore

# ── Scripts (dev-only helper scripts) ─────────────────────────────────────────
scripts/

# ── Alembic version history (migrations are copied explicitly) ────────────────
# alembic/ is intentionally NOT excluded — migrations run inside the container.

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── pre-commit / security baseline ───────────────────────────────────────────
.pre-commit-config.yaml
.secrets.baseline
