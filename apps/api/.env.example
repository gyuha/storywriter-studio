# ============================================================
# FastAPI Bootstrap — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
#
# ── Local dev topology ────────────────────────────────────
#   Docker containers : postgres / redis / mailpit
#   FastAPI app       : host (uv run uvicorn --reload)
#
#   Containers expose ports to the host at the values below,
#   so POSTGRES_HOST=localhost / REDIS_HOST=localhost / etc.
#   is correct for host-to-container connectivity.
#   Change only if you remap the host-side ports in
#   docker-compose.yml or run inside docker-compose network.
# ============================================================

# ── QUICK START (only these must be changed before first boot) ────────────────
#
#   1. SECRET_KEY     → openssl rand -hex 32
#   2. JWT_SECRET_KEY → openssl rand -hex 32  (must differ from SECRET_KEY)

#   3. LLM API key(s) → set only the one matching LLM_PROVIDER

#   4. OAuth secrets  → set only the providers you selected during cookiecutter
#
# Template metadata rendered from cookiecutter:
#   project=fastapi-bootstrap package=app api=http://localhost:8000
#
# Everything else has safe defaults for local development.
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
APP_DEBUG=false
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
FRONTEND_URL=http://localhost:3000
# Password reset emails append the token to this frontend reset-confirm route base.
FRONTEND_RESET_CONFIRM_URL_BASE=http://localhost:3000/auth/reset-confirm
# Allowed CORS origins — JSON array format required by pydantic-settings
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]


# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1                      # Increase to CPU-count in production


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  TOPOLOGY                                                                │
# │  Local dev  : POSTGRES_HOST=localhost (app on host → postgres container) │
# │  Full docker: docker-compose overrides DATABASE_URL with host=postgres   │
# │               (app container → postgres container via compose network)   │
# └──────────────────────────────────────────────────────────────────────────┘
# docker-compose.yml maps 127.0.0.1:${POSTGRES_PORT}:5432 so localhost works on the host only.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app_db

# Full async DSN used by SQLAlchemy (asyncpg driver).
# If set, POSTGRES_* component vars above are ignored by the app.
# NOTE: Local dev runs the app on the host via 'make dev' / 'just dev'.
#       Containerized app execution is defined only in docker-compose.prod.yml.
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app_db

# Sync DSN used by Alembic migrations (psycopg2 / standard driver).
# alembic/env.py reads this variable directly.
# IMPORTANT: Must use psycopg2 driver — asyncpg is NOT supported by Alembic.
DATABASE_URL_SYNC=postgresql+psycopg2://app:app@localhost:5432/app_db


# ── Redis ─────────────────────────────────────────────────────────────────────
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  TOPOLOGY                                                                │
# │  Local dev  : REDIS_HOST=localhost (app on host → redis container)      │
# │  Prod app   : docker-compose.prod.yml overrides REDIS_URL with redis    │
# │               (app container → redis container via compose network)      │
# └──────────────────────────────────────────────────────────────────────────┘
# docker-compose.yml maps 127.0.0.1:${REDIS_PORT}:6379 so localhost works on the host only.
# Redis is used for: JWT blacklist · rate limiting · OAuth state nonce ·
#                    SSE fan-out channel · general cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Full DSN — if set, REDIS_* component vars above are ignored by the app.
# NOTE: Local dev runs the app on the host via 'make dev' / 'just dev'.
#       Containerized app execution is defined only in docker-compose.prod.yml.
REDIS_URL=redis://localhost:6379/0


# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32  (keep distinct from SECRET_KEY)
JWT_SECRET_KEY=change-me-jwt-secret-key-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
# Access token TTL in minutes (default: 15 min)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token TTL in days (default: 7 days). Rotation + reuse detection enabled.
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ── OAuth ─────────────────────────────────────────────────────────────────────
# Only fill in the providers you enabled during cookiecutter setup.
# Unused provider files were removed by the post-generation hook.


# ── OAuth — Google ────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:8000/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback



# ── OAuth — Kakao ─────────────────────────────────────────────────────────────
# Create app at: https://developers.kakao.com/console/app
# Add http://localhost:8000/api/v1/auth/oauth/kakao/callback to allowed redirect URIs
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/kakao/callback



# ── OAuth — Naver ─────────────────────────────────────────────────────────────
# Create app at: https://developers.naver.com/apps/#/list
# Add http://localhost:8000/api/v1/auth/oauth/naver/callback to allowed redirect URIs
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/naver/callback



# ── Email / SMTP ──────────────────────────────────────────────────────────────
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  TOPOLOGY                                                                │
# │  Local dev  : MAIL_SERVER=localhost (host app → Mailpit container SMTP) │
# │  Production : docker-compose.prod.yml injects real SMTP env values      │
# │               (Mailpit is intentionally excluded from prod profile)     │
# └──────────────────────────────────────────────────────────────────────────┘
# Dev  : Mailpit catches all outgoing mail; no real credentials needed.
#        SMTP → localhost:1025   Web UI → http://localhost:8025
# Prod : Replace with real SMTP credentials (AWS SES, SendGrid, Postmark …).
#
# settings.mail_connection_config assembles these into ConnectionConfig(**kwargs)
# ready for fastapi-mail:
#   from fastapi_mail import ConnectionConfig, FastMail
#   mailer = FastMail(ConnectionConfig(**settings.mail_connection_config))

# Localhost-only host port that docker-compose binds for Mailpit SMTP (127.0.0.1 -> container:1025)
MAILPIT_SMTP_PORT=1025
# Localhost-only host port for Mailpit Web UI (127.0.0.1 -> container:8025)
MAILPIT_UI_PORT=8025

# FastAPI-Mail connection settings
# NOTE: These values are correct for the default host-side dev mode.
#       Production container SMTP settings live in docker-compose.prod.yml / .env.prod.
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@fastapi-bootstrap.example.com
MAIL_FROM_NAME=FastAPI Bootstrap
MAIL_STARTTLS=false
MAIL_SSL_TLS=false

# Production example (uncomment and fill in):
# MAIL_SERVER=smtp.fastapi-bootstrap.local
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key
# MAIL_FROM=noreply@fastapi-bootstrap.example.com
# MAIL_FROM_NAME=FastAPI Bootstrap
# MAIL_STARTTLS=true
# MAIL_SSL_TLS=false


# ── LLM / Chat Domain ─────────────────────────────────────────────────────────
# LLM_PROVIDER is the single switch that selects which provider + API key is
# used at runtime.  Change LLM_PROVIDER (and the matching key below) — nothing
# else in the application code needs to change.
#
# LLM_STACK=langchain-litellm (LangChain Runnable + langchain-litellm adapter)
# Valid values: openai | anthropic | gemini | azure | ollama
#
# The LangChain/LiteLLM stack assembles the full model string automatically:
#   "<provider>/<model>"   e.g.  openai/gpt-4o-mini
#
# ── Provider quick-switch guide ───────────────────────────────────────────────
#
#   ▸ OpenAI (default):
#       LLM_PROVIDER=openai
#       LLM_DEFAULT_MODEL=gpt-4o-mini
#       OPENAI_API_KEY=sk-...          ← only this key is read
#
#   ▸ Anthropic:
#       LLM_PROVIDER=anthropic
#       LLM_DEFAULT_MODEL=claude-3-5-sonnet-20241022
#       ANTHROPIC_API_KEY=sk-ant-...   ← only this key is read
#
#   ▸ Google Gemini:
#       LLM_PROVIDER=gemini
#       LLM_DEFAULT_MODEL=gemini-1.5-flash
#       GEMINI_API_KEY=AIza...         ← only this key is read
#
#   ▸ Azure OpenAI:
#       LLM_PROVIDER=azure
#       LLM_DEFAULT_MODEL=gpt-4o          ← used as fallback if DEPLOYMENT empty
#       AZURE_OPENAI_API_KEY=...
#       AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
#       AZURE_OPENAI_DEPLOYMENT=my-deployment-name
#       AZURE_OPENAI_API_VERSION=2024-08-01-preview
#
#   ▸ Ollama (local inference — no API key required):
#       LLM_PROVIDER=ollama
#       LLM_DEFAULT_MODEL=llama3.2
#       OLLAMA_BASE_URL=http://localhost:11434
#
# ── Active configuration ──────────────────────────────────────────────────────
# Set LLM_PROVIDER to your chosen provider, then fill in the matching key only.
# Supported values: openai | anthropic | gemini | azure | ollama
LLM_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-4o-mini

# API keys — set ONLY the key for the active provider; leave others blank.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Azure OpenAI — only needed when LLM_PROVIDER=azure
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Ollama — only needed when LLM_PROVIDER=ollama (no API key required)
OLLAMA_BASE_URL=http://localhost:11434

# ── LLM Generation parameters ─────────────────────────────────────────────────
# These apply globally to all chat completions.
# Individual requests can override per-call via the API payload.
#
# LLM_TEMPERATURE : float  0.0 (fully deterministic) → 2.0 (maximum creativity)
#                          Default: 0.7  Recommended for chat: 0.7–1.0
# LLM_MAX_TOKENS  : int    Maximum tokens to generate per response.
#                          Default: 2048  (increase for longer documents)
# LLM_STREAMING   : bool   true = SSE token-by-token streaming (default)
#                          false = wait for the full response before sending
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_STREAMING=true


# ── Observability ─────────────────────────────────────────────────────────────
# structlog emits JSON by default. Use "console" for human-readable dev output.
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                # json | console
