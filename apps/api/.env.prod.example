# ============================================================
# FastAPI Bootstrap — Production Environment Variables
# ============================================================
# 이 파일을 .env.prod로 복사하고 실제 값으로 채우세요:
#   cp .env.prod.example .env.prod
#
# NEVER commit .env.prod to version control.
# (.gitignore에 .env.prod가 포함되어 있는지 확인하세요)
#
# ── 운영 환경 토폴로지 ────────────────────────────────────
#   Docker 컨테이너: postgres / redis
#   FastAPI 앱     : 컨테이너 (app 서비스, --profile prod)
#   SMTP           : 실제 SMTP 서버 (Mailpit 사용 안 함)
#
#   컨테이너 간 통신은 서비스명(hostname)으로 이루어집니다.
#   docker-compose.prod.yml이 DATABASE_URL/REDIS_URL을 자동으로
#   컨테이너 서비스명 기반으로 설정하므로 아래 값은 그대로 유지됩니다.
#
# Template metadata rendered from cookiecutter:
#   project=fastapi-bootstrap package=app api=http://localhost:8000
# ============================================================

# ── QUICK START (이것들만 변경하면 됩니다) ───────────────────────────────────
#
#   1. SECRET_KEY       → openssl rand -hex 32
#   2. JWT_SECRET_KEY   → openssl rand -hex 32  (SECRET_KEY와 달라야 함)
#   3. POSTGRES_USER    → 운영 DB 사용자
#   4. POSTGRES_PASSWORD → 강력한 비밀번호
#   5. MAIL_SERVER      → 실제 SMTP 서버 (SendGrid, SES, Postmark 등)

#   6. LLM API 키       → LLM_PROVIDER에 맞는 키 설정

# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE-ME-use-openssl-rand-hex-32-for-production
# Allowed CORS origins — cookiecutter frontend_url 기본값을 렌더링합니다.
# 운영에서는 frontend_url을 실제 도메인으로 생성하거나 아래 값을 수정하세요.
FRONTEND_URL=http://localhost:3000
# Password reset emails append the token to this frontend reset-confirm route base.
FRONTEND_RESET_CONFIRM_URL_BASE=http://localhost:3000/auth/reset-confirm
CORS_ORIGINS=["http://localhost:3000"]


# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4                      # CPU 코어 수에 맞게 조정 (예: 2 * CPU + 1)


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# 컨테이너 간 통신: 서비스명 'postgres' 사용 (docker-compose.prod.yml 자동 설정)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=app          # 운영에서는 필요 시 cookiecutter 생성값에서 변경
POSTGRES_PASSWORD=CHANGE-ME-strong-production-password
POSTGRES_DB=app_db

# Full DSN (docker-compose.prod.yml이 컨테이너 서비스명으로 자동 설정)
DATABASE_URL=postgresql+asyncpg://app:CHANGE-ME-strong-production-password@postgres:5432/app_db
DATABASE_URL_SYNC=postgresql+psycopg2://app:CHANGE-ME-strong-production-password@postgres:5432/app_db


# ── Redis ─────────────────────────────────────────────────────────────────────
# 컨테이너 간 통신: 서비스명 'redis' 사용
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

REDIS_URL=redis://redis:6379/0


# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32  (SECRET_KEY와 반드시 다른 값)
JWT_SECRET_KEY=CHANGE-ME-jwt-secret-use-openssl-rand-hex-32-for-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ── OAuth ─────────────────────────────────────────────────────────────────────
# 사용하는 프로바이더의 시크릿만 입력하세요.
# Callback URI는 실제 운영 도메인으로 변경하세요.


# ── OAuth — Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback



# ── OAuth — Kakao ─────────────────────────────────────────────────────────────
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/kakao/callback



# ── OAuth — Naver ─────────────────────────────────────────────────────────────
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/naver/callback



# ── Email / SMTP ──────────────────────────────────────────────────────────────
# 프로덕션에서는 실제 SMTP 서비스를 사용하세요 (Mailpit 사용 안 함).
# docker-compose.prod.yml의 environment 블록이 이 값들을 참조합니다.
#
# 주요 SMTP 서비스 예시:
#   SendGrid : smtp.sendgrid.net:587  (STARTTLS)
#   AWS SES  : email-smtp.us-east-1.amazonaws.com:587  (STARTTLS)
#   Postmark : smtp.postmarkapp.com:587  (STARTTLS)
#   Mailgun  : smtp.mailgun.org:587  (STARTTLS)

# 아래 값이 docker-compose.prod.yml의 ${MAIL_SERVER} / ${MAIL_PORT} 변수를 채웁니다.
MAIL_SERVER=smtp.fastapi-bootstrap.local
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your-sendgrid-api-key-or-smtp-password
MAIL_FROM=noreply@fastapi-bootstrap.example.com
MAIL_FROM_NAME=FastAPI Bootstrap
MAIL_STARTTLS=true
MAIL_SSL_TLS=false


# ── LLM / Chat Domain ─────────────────────────────────────────────────────────
# LLM_PROVIDER를 선택하고 해당하는 API 키만 입력하세요.
# LLM_STACK=langchain-litellm (LangChain Runnable + langchain-litellm adapter)
# Supported values: openai | anthropic | gemini | azure | ollama
LLM_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-4o-mini

# API 키 — 활성 프로바이더의 키만 입력하세요; 나머지는 비워두세요.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Azure OpenAI — LLM_PROVIDER=azure일 때만 필요
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Ollama — LLM_PROVIDER=ollama일 때만 필요 (API 키 불필요)
OLLAMA_BASE_URL=http://localhost:11434

# LLM 생성 파라미터
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_STREAMING=true


# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                 # 운영 환경 권장: INFO 또는 WARNING
LOG_FORMAT=json                # 운영 환경 권장: json (로그 수집기 파싱 가능)
